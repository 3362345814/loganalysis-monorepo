services:
  postgres:
    image: postgres:15
    container_name: {{ .ProjectName }}-postgres
    environment:
      POSTGRES_USER: loganalysis
      POSTGRES_PASSWORD: loganalysis_123456
      POSTGRES_DB: loganalysis
      TZ: Asia/Shanghai
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "{{ .Ports.Postgres }}:5432"
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U loganalysis"]
      interval: 10s
      timeout: 5s
      retries: 8
    networks:
      - loganalysis-network

  redis:
    image: redis:7-alpine
    container_name: {{ .ProjectName }}-redis
    command: redis-server --requirepass loganalysis_123456 --appendonly yes
    environment:
      TZ: Asia/Shanghai
    volumes:
      - redis_data:/data
    ports:
      - "{{ .Ports.Redis }}:6379"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "loganalysis_123456", "ping"]
      interval: 10s
      timeout: 5s
      retries: 8
    networks:
      - loganalysis-network

volumes:
  postgres_data:
  redis_data:

networks:
  loganalysis-network:
    driver: bridge
